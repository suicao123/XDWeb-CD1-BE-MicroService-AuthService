<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <div style="margin: 25px" class="">
      <div class="d-flex justify-content-between align-content-center">
        <h1>List User: </h1>
        <!-- <img src="images/hoidanit.png" alt="" srcset="" /> -->
        <div class="">
          <a class="btn btn-primary" href="/create-user">Create new user</a>
        </div>
      </div>
      <hr />
      <div class="">
        <table class="table table-hover table-bordered">
          <thead>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Address</th>
            <th>Action</th>
          </thead>
          <tbody>
              <% users.forEach( function (user) { %>
              <tr>
                    <td><%= user.id %></td>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.address %></td>
                    <td class="d-flex gap-2">
                      <form action="/handelDeleteUser/<%= user.id %>" method="post">
                        <button class="btn btn-danger" type="submit" >Delete</button>
                      </form>
                      <form action="/handelViewUser/<%= user.id %>" method="get">
                        <button class="btn btn-warning" type="submit" >View</button>
                      </form>
                    </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
