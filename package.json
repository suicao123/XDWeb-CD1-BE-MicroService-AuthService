{
  "name": "nodejs-pro",
  "version": "1.0.0",
  "description": "nodejs -pro ",
  "main": "app.js",
  "scripts": {
  "build": "tsc && tsc-alias",
  "start": "node dist/app.js",
  "dev": "nodemon -r ts-node/register -r tsconfig-paths/register src/app.ts",
  "test": "echo \"Error: no test specified\" && exit 1"
},
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "node_modules"
    ],
    "exec": "ts-node -r tsconfig-paths/register ./src/app.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MnhWuanz/nodejs-pro.git"
  },
  "keywords": [
    "nodejs"
  ],
  "author": "MnhQuan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MnhWuanz/nodejs-pro/issues"
  },
  "homepage": "https://github.com/MnhWuanz/nodejs-pro#readme",
  "dependencies": {
    "@prisma/client": "6.3.0",
    "@quixo3/prisma-session-store": "3.1.13",
    "@types/cors": "^2.8.19",
    "@types/otp-generator": "^4.0.2",
    "bcrypt": "5.1.1",
    "cors": "^2.8.6",
    "dotenv": "16.4.7",
    "ejs": "3.1.10",
    "express": "^5.2.1",
    "express-session": "1.18.1",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.12.0",
    "nodemailer": "^8.0.2",
    "otp-generator": "^4.0.1",
    "passport": "0.7.0",
    "passport-local": "1.0.0",
    "resend": "^6.9.3",
    "uuid": "11.0.5",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.0",
    "@types/express-session": "1.18.1",
    "@types/jsonwebtoken": "9.0.9",
    "@types/multer": "1.4.12",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "1.0.17",
    "@types/passport-local": "1.0.38",
    "nodemon": "3.1.9",
    "prisma": "^6.3.0",
    "ts-node": "10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.3"
  }
}
